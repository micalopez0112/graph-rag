# ──────────────────────────────────────────────────────────────────────────────
# .env.example
# Copy this file to .env and fill in your real AWS values.
# NEVER commit .env to git — it contains secrets.
# ──────────────────────────────────────────────────────────────────────────────

# ── AWS ───────────────────────────────────────────────────────────────────────
AWS_REGION=us-east-1
# Your AWS account's default region. Use us-east-1 as a beginner — most services
# are available there and it is well-documented.

# ── Neo4j (Graph Database — runs locally in Docker) ─────────────────────────
NEO4J_URI=bolt://localhost:7687
# Use bolt://localhost:7687 when running Neo4j in Docker on the same machine.
# On Cloud9: bolt://localhost:7687 (Docker runs on the same EC2 instance).

NEO4J_USER=neo4j
NEO4J_PASSWORD=graphrag123
# These match the -e NEO4J_AUTH=neo4j/graphrag123 flag in the docker run command.

# ── Amazon RDS PostgreSQL (Vector Database) ───────────────────────────────────
RDS_HOST=your-db-instance.xxxx.us-east-1.rds.amazonaws.com
# Found in: AWS Console → RDS → Databases → your DB → "Endpoint"

RDS_PORT=5432
RDS_DB_NAME=graphrag
RDS_USER=graphrag_admin
RDS_PASSWORD=YourStrongPasswordHere
# Choose a strong password when you create the RDS instance.

# ── Embeddings & LLM ──────────────────────────────────────────────────────────
EMBEDDING_PROVIDER=bedrock
# Options: "bedrock" (Amazon Titan, free with credits) or "openai"

LLM_PROVIDER=bedrock
# Options: "bedrock" (Claude 3 Sonnet) or "openai" (GPT-4)

EMBEDDING_DIM=1536
# 1536 for Bedrock Titan / OpenAI ada-002
# 384 if using local HuggingFace all-MiniLM-L6-v2

# ── Optional: OpenAI (if not using Bedrock) ───────────────────────────────────
# OPENAI_API_KEY=sk-...

# ── Retrieval Tuning ──────────────────────────────────────────────────────────
TOP_K_CHUNKS=5
# How many text chunks to retrieve per query. Higher = more context but more tokens.

GRAPH_DEPTH=1
# Hop depth for graph traversal. 1 = direct neighbours only.
# 2 = neighbours of neighbours (can be slow for large graphs).

SEMANTIC_THRESHOLD=0.75
# Cosine similarity threshold (0.0-1.0) for semantic chunk→node linking.
# Lower = more links (potentially noisy). Higher = fewer, more precise links.

# ── Chatbot ───────────────────────────────────────────────────────────────────
CHUNK_SIZE=512
CHUNK_OVERLAP=64
CHATBOT_PORT=8080
